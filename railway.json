{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildCommand": "pnpm install && pnpm --filter @predikt/api prisma:generate && pnpm --filter @predikt/api build"
  },
  "deploy": {
    "startCommand": "start:prod": "prisma migrate deploy && node dist/main.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
