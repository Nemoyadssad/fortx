# Postgres
DATABASE_URL="postgresql://predikt:predikt@localhost:5432/predikt?schema=public"

# Auth
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="15m"

# CORS / web app origin
WEB_ORIGIN="http://localhost:3000"
PORT=4000

# Seed superadmin (used by db:seed)
SEED_ADMIN_EMAIL="admin@predikt.local"
SEED_ADMIN_PASSWORD="changeme12345"

# Google OAuth (next phase)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Polymarket Gamma (next phase) — public, no key needed
POLYMARKET_GAMMA_URL="https://gamma-api.polymarket.com"

# Testing helper: lets a logged-in user top up their own balance via POST /dev/topup.
# Set to "false" in production.
ENABLE_DEV_TOPUP="true"
